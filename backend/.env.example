# Clé API Anthropic (à récupérer sur https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Modèle Claude à utiliser (vérifie la doc pour le nom exact du modèle disponible)
CLAUDE_MODEL=claude-sonnet-4-5

# Origines CORS autorisées (séparées par des virgules)
CORS_ORIGINS=https://initiales.example.com,http://localhost:5173

# Chemin de la base SQLite
DB_PATH=/var/lib/initiales/initiales.db
